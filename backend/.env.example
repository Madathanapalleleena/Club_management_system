# Copy this to .env and fill in real values for local dev.
# On Render, set these in Dashboard -> Environment.

# --- Required ---
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/clubms?retryWrites=true&w=majority
JWT_SECRET=change-me-to-a-long-random-string

# --- CORS (production only) ---
# Leave empty if frontend is served from the same backend service (single-service deploy).
# If you host the frontend separately, list allowed origins comma-separated:
# CLIENT_URLS=https://clubms.onrender.com,https://app.yourclub.com
CLIENT_URLS=

# --- Cloudinary (optional, for image uploads to survive Render restarts) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
